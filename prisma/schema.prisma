// Farm-to-Grocer MVP - Prisma Schema
// Database: SQLite (dev) / PostgreSQL (production)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  phone         String?
  role          String    @default("FARMER") // FARMER, GROCER, ADMIN
  status        String    @default("PENDING") // PENDING, ACTIVE, SUSPENDED
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  farmer        Farmer?
  grocer        Grocer?
  sessions      Session[]
  accounts      Account[]
  notifications Notification[]
  activities    Activity[]

  @@index([email])
  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// FARMER PROFILE & PRODUCTS
// ============================================

model Farmer {
  id                 String   @id @default(cuid())
  userId             String   @unique
  farmName           String
  description        String?
  address            String
  city               String
  state              String
  zipCode            String
  latitude           Float?
  longitude          Float?
  certifications     String   @default("[]") // JSON array
  rating             Float    @default(0)
  totalSales         Int      @default(0)
  isVerified         Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  products       Product[]
  orders         Order[]       @relation("FarmerOrders")
  connections    Connection[]  @relation("FarmerConnections")
  promotions     Promotion[]
  invoices       Invoice[]     @relation("FarmerInvoices")

  // Additional fields
  phone              String?
  deliveryDays       String   @default("[]") // JSON array
  leadTimeDays       Int?     @default(2)
  minimumOrderAmount Float?   @default(0)
  story              String?

  @@index([city, state])
  @@index([isVerified])
}

model Product {
  id              String   @id @default(cuid())
  farmerId        String
  name            String
  description     String?
  category        String   // VEGETABLES, FRUITS, DAIRY, MEAT, POULTRY, GRAINS, HERBS, EGGS, HONEY, OTHER
  unit            String   // LB, KG, OZ, BUNCH, DOZEN, GALLON, LITER, PIECE, CASE, PALLET
  pricePerUnit    Float
  packSize        String   @default("1 unit")
  minOrderQty     Int      @default(1)
  maxOrderQty     Int?
  availableQty    Int
  images          String   @default("[]") // JSON array
  isOrganic       Boolean  @default(false)
  harvestDate     DateTime?
  expiryDate      DateTime?
  status          String   @default("ACTIVE") // DRAFT, ACTIVE, OUT_OF_STOCK, DISCONTINUED
  tags            String   @default("[]") // JSON array
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  farmer          Farmer     @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  orderItems      OrderItem[]
  cartItems       CartItem[]

  @@index([farmerId])
  @@index([category])
  @@index([status])
  @@index([name])
}

// ============================================
// GROCER PROFILE & CART
// ============================================

model Grocer {
  id            String   @id @default(cuid())
  userId        String   @unique
  businessName  String
  businessType  String
  description   String?
  address       String
  city          String
  state         String
  zipCode       String
  latitude      Float?
  longitude     Float?
  taxId         String?
  isVerified    Boolean  @default(false)
  totalOrders   Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders        Order[]      @relation("GrocerOrders")
  cartItems     CartItem[]
  savedFarmers  SavedFarmer[]
  connections   Connection[] @relation("GrocerConnections")
  invoices      Invoice[]    @relation("GrocerInvoices")

  // Additional fields
  phone                 String?
  receivingAddress      String?
  receivingDays         String   @default("[]") // JSON array
  preferredDeliveryDays String   @default("[]") // JSON array
  categoriesOfInterest  String   @default("[]") // JSON array

  @@index([city, state])
  @@index([isVerified])
}

model CartItem {
  id        String   @id @default(cuid())
  grocerId  String
  productId String
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  grocer    Grocer   @relation(fields: [grocerId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([grocerId, productId])
}

model SavedFarmer {
  id        String   @id @default(cuid())
  grocerId  String
  farmerId  String
  createdAt DateTime @default(now())

  // Relations
  grocer    Grocer   @relation(fields: [grocerId], references: [id], onDelete: Cascade)

  @@unique([grocerId, farmerId])
}

// ============================================
// B2B CONNECTIONS
// ============================================

model Connection {
  id          String    @id @default(cuid())
  farmerId    String
  grocerId    String
  status      String    @default("PENDING") // PENDING, APPROVED, DECLINED
  requestedAt DateTime  @default(now())
  approvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  farmer      Farmer    @relation("FarmerConnections", fields: [farmerId], references: [id], onDelete: Cascade)
  grocer      Grocer    @relation("GrocerConnections", fields: [grocerId], references: [id], onDelete: Cascade)

  @@unique([farmerId, grocerId])
  @@index([farmerId])
  @@index([grocerId])
  @@index([status])
}

// ============================================
// ORDERS & TRANSACTIONS
// ============================================

model Order {
  id              String    @id @default(cuid())
  orderNumber     String    @unique
  farmerId        String
  grocerId        String
  status          String    @default("PENDING") // PENDING, CONFIRMED, PROCESSING, READY_FOR_PICKUP, OUT_FOR_DELIVERY, DELIVERED, CANCELLED, REFUNDED
  paymentStatus   String    @default("PENDING") // PENDING, PAID, FAILED, REFUNDED
  deliveryMethod  String    // PICKUP, DELIVERY
  subtotal        Float
  tax             Float     @default(0)
  deliveryFee     Float     @default(0)
  total           Float
  notes           String?
  deliveryAddress String?
  deliveryDate    DateTime?
  confirmedAt     DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  farmer          Farmer      @relation("FarmerOrders", fields: [farmerId], references: [id])
  grocer          Grocer      @relation("GrocerOrders", fields: [grocerId], references: [id])
  items           OrderItem[]
  payment         Payment?
  messages        OrderMessage[]
  invoice         Invoice?

  @@index([farmerId])
  @@index([grocerId])
  @@index([status])
  @@index([orderNumber])
}

model OrderItem {
  id           String  @id @default(cuid())
  orderId      String
  productId    String
  productName  String
  quantity     Int
  pricePerUnit Float
  total        Float

  // Relations
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product @relation(fields: [productId], references: [id])

  @@index([orderId])
}

model Payment {
  id              String    @id @default(cuid())
  orderId         String    @unique
  amount          Float
  method          String
  transactionId   String?
  status          String    @default("PENDING") // PENDING, PAID, FAILED, REFUNDED
  paidAt          DateTime?
  refundedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ============================================
// PROMOTIONS
// ============================================

model Promotion {
  id             String   @id @default(cuid())
  farmerId       String
  name           String
  description    String
  type           String   // PERCENTAGE, FIXED, BOGO
  value          Float
  minOrderAmount Float    @default(0)
  maxUses        Int?
  usedCount      Int      @default(0)
  startDate      String   // ISO date string
  endDate        String   // ISO date string
  isActive       Boolean  @default(true)
  products       String   @default("[]") // JSON array of product IDs
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  farmer         Farmer   @relation(fields: [farmerId], references: [id], onDelete: Cascade)
}

// ============================================
// INVOICES
// ============================================

model Invoice {
  id            String   @id @default(cuid())
  orderId       String   @unique
  farmerId      String
  grocerId      String
  invoiceNumber String   @unique
  amount        Float
  tax           Float    @default(0)
  total         Float
  status        String   @default("DRAFT") // DRAFT, SENT, PAID, OVERDUE, CANCELLED
  dueDate       String
  paidAt        String?
  paymentMethod String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  order         Order    @relation(fields: [orderId], references: [id])
  farmer        Farmer   @relation("FarmerInvoices", fields: [farmerId], references: [id])
  grocer        Grocer   @relation("GrocerInvoices", fields: [grocerId], references: [id])
}

// ============================================
// MESSAGING & NOTIFICATIONS
// ============================================

model OrderMessage {
  id        String   @id @default(cuid())
  orderId   String
  senderId  String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  subject    String
  body       String
  isRead     Boolean  @default(false)
  threadId   String?
  createdAt  DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // ORDER_PLACED, ORDER_CONFIRMED, ORDER_SHIPPED, ORDER_DELIVERED, ORDER_CANCELLED, NEW_MESSAGE, PRODUCT_LOW_STOCK, PAYMENT_RECEIVED, SYSTEM
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

// ============================================
// ACTIVITY LOG
// ============================================

model Activity {
  id          String   @id @default(cuid())
  userId      String
  type        String
  description String
  metadata    String   @default("{}") // JSON
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}
