{
  "name": "farm-to-grocer-mvp",
  "version": "1.0.0",
  "description": "A marketplace connecting local farmers directly with grocers and restaurants",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
