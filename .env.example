# ═══════════════════════════════════════════════════════════════
# FARM-TO-GROCER MVP - ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════════
# 
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
#
# Required variables are marked with [REQUIRED]
# Optional variables are marked with [OPTIONAL]
#
# ═══════════════════════════════════════════════════════════════


# ───────────────────────────────────────────────────────────────
# APPLICATION
# ───────────────────────────────────────────────────────────────

# [REQUIRED] Application URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# [OPTIONAL] Application name
NEXT_PUBLIC_APP_NAME="Farm to Grocer"

# [OPTIONAL] Environment (development, staging, production)
NODE_ENV=development


# ───────────────────────────────────────────────────────────────
# DATABASE (PostgreSQL)
# ───────────────────────────────────────────────────────────────

# [REQUIRED] PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# 
# Local development example:
# DATABASE_URL="postgresql://postgres:password@localhost:5432/farmtogrocer?schema=public"
#
# Neon (serverless) example:
# DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/farmtogrocer?sslmode=require"
#
# Supabase example:
# DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"
#
DATABASE_URL="postgresql://postgres:password@localhost:5432/farmtogrocer?schema=public"

# [OPTIONAL] Direct connection URL (for migrations, bypasses connection pooling)
DIRECT_URL="postgresql://postgres:password@localhost:5432/farmtogrocer?schema=public"


# ───────────────────────────────────────────────────────────────
# AUTHENTICATION (NextAuth.js)
# ───────────────────────────────────────────────────────────────

# [REQUIRED] NextAuth secret key
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"

# [REQUIRED] NextAuth URL (same as NEXT_PUBLIC_APP_URL)
NEXTAUTH_URL="http://localhost:3000"

# [OPTIONAL] Debug mode for NextAuth
NEXTAUTH_DEBUG=false


# ───────────────────────────────────────────────────────────────
# OAUTH PROVIDERS
# ───────────────────────────────────────────────────────────────

# [OPTIONAL] Google OAuth
# Get credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# [OPTIONAL] GitHub OAuth (if needed)
# Get credentials at: https://github.com/settings/developers
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# [OPTIONAL] Facebook OAuth (if needed)
# Get credentials at: https://developers.facebook.com/apps
FACEBOOK_CLIENT_ID="your-facebook-app-id"
FACEBOOK_CLIENT_SECRET="your-facebook-app-secret"


# ───────────────────────────────────────────────────────────────
# EMAIL (Magic Links & Notifications)
# ───────────────────────────────────────────────────────────────

# [OPTIONAL] Email provider for magic links
# SMTP configuration
EMAIL_SERVER_HOST="smtp.example.com"
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER="your-email@example.com"
EMAIL_SERVER_PASSWORD="your-email-password"
EMAIL_FROM="Farm to Grocer <noreply@farmtogrocer.com>"

# [OPTIONAL] Resend (recommended for transactional emails)
# Get API key at: https://resend.com
RESEND_API_KEY="re_xxxxxxxxxxxx"

# [OPTIONAL] SendGrid
# Get API key at: https://sendgrid.com
SENDGRID_API_KEY="SG.xxxxxxxxxxxx"


# ───────────────────────────────────────────────────────────────
# PAYMENTS (Stripe)
# ───────────────────────────────────────────────────────────────

# [REQUIRED for payments] Stripe API keys
# Get keys at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxx"

# [REQUIRED for payments] Stripe webhook secret
# Get from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxx"

# [OPTIONAL] Stripe Connect (for farmer payouts)
STRIPE_CONNECT_CLIENT_ID="ca_xxxxxxxxxxxx"


# ───────────────────────────────────────────────────────────────
# FILE UPLOADS (UploadThing)
# ───────────────────────────────────────────────────────────────

# [REQUIRED for uploads] UploadThing credentials
# Get at: https://uploadthing.com/dashboard
UPLOADTHING_SECRET="sk_live_xxxxxxxxxxxx"
UPLOADTHING_APP_ID="xxxxxxxxxxxx"

# [OPTIONAL] Alternative: AWS S3
AWS_ACCESS_KEY_ID="AKIAXXXXXXXXXXXXXXXX"
AWS_SECRET_ACCESS_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="farmtogrocer-uploads"

# [OPTIONAL] Alternative: Cloudinary
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="xxxxxxxxxxxx"
CLOUDINARY_API_SECRET="xxxxxxxxxxxx"


# ───────────────────────────────────────────────────────────────
# MAPS & GEOLOCATION
# ───────────────────────────────────────────────────────────────

# [OPTIONAL] Google Maps API
# Get at: https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# [OPTIONAL] Mapbox (alternative to Google Maps)
# Get at: https://account.mapbox.com/access-tokens
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN="pk.xxxxxxxxxxxx"


# ───────────────────────────────────────────────────────────────
# ANALYTICS & MONITORING
# ───────────────────────────────────────────────────────────────

# [OPTIONAL] Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# [OPTIONAL] PostHog (product analytics)
# Get at: https://posthog.com
NEXT_PUBLIC_POSTHOG_KEY="phc_xxxxxxxxxxxx"
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# [OPTIONAL] Vercel Analytics
NEXT_PUBLIC_VERCEL_ANALYTICS_ID="xxxxxxxxxxxx"

# [OPTIONAL] Sentry (error tracking)
# Get at: https://sentry.io
SENTRY_DSN="https://xxxxxxxxxxxx@o0.ingest.sentry.io/0"
SENTRY_AUTH_TOKEN="sntrys_xxxxxxxxxxxx"
SENTRY_ORG="your-org"
SENTRY_PROJECT="farm-to-grocer"

# [OPTIONAL] LogRocket (session replay)
NEXT_PUBLIC_LOGROCKET_APP_ID="xxxxx/farm-to-grocer"


# ───────────────────────────────────────────────────────────────
# CACHING & RATE LIMITING
# ───────────────────────────────────────────────────────────────

# [OPTIONAL] Redis (for caching & rate limiting)
# Get at: https://upstash.com or https://redis.com
REDIS_URL="redis://default:xxxxxxxxxxxx@xxx.upstash.io:6379"

# [OPTIONAL] Upstash Redis REST API
UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="xxxxxxxxxxxx"


# ───────────────────────────────────────────────────────────────
# SEARCH
# ───────────────────────────────────────────────────────────────

# [OPTIONAL] Algolia (search)
# Get at: https://www.algolia.com
NEXT_PUBLIC_ALGOLIA_APP_ID="xxxxxxxxxxxx"
NEXT_PUBLIC_ALGOLIA_SEARCH_API_KEY="xxxxxxxxxxxx"
ALGOLIA_ADMIN_API_KEY="xxxxxxxxxxxx"

# [OPTIONAL] Meilisearch (self-hosted alternative)
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY="xxxxxxxxxxxx"


# ───────────────────────────────────────────────────────────────
# NOTIFICATIONS (Push & SMS)
# ───────────────────────────────────────────────────────────────

# [OPTIONAL] Twilio (SMS notifications)
# Get at: https://www.twilio.com/console
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="xxxxxxxxxxxx"
TWILIO_PHONE_NUMBER="+1234567890"

# [OPTIONAL] OneSignal (push notifications)
# Get at: https://onesignal.com
NEXT_PUBLIC_ONESIGNAL_APP_ID="xxxxxxxxxxxx"
ONESIGNAL_REST_API_KEY="xxxxxxxxxxxx"


# ───────────────────────────────────────────────────────────────
# AI & MACHINE LEARNING (Optional)
# ───────────────────────────────────────────────────────────────

# [OPTIONAL] OpenAI (for AI features)
OPENAI_API_KEY="sk-xxxxxxxxxxxx"

# [OPTIONAL] Anthropic Claude
ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxxxx"


# ───────────────────────────────────────────────────────────────
# DEVELOPMENT & TESTING
# ───────────────────────────────────────────────────────────────

# [OPTIONAL] Enable debug logging
DEBUG=false

# [OPTIONAL] Disable telemetry
NEXT_TELEMETRY_DISABLED=1

# [OPTIONAL] Bundle analyzer
ANALYZE=false

# [OPTIONAL] Test database URL (for running tests)
TEST_DATABASE_URL="postgresql://postgres:password@localhost:5432/farmtogrocer_test?schema=public"


# ───────────────────────────────────────────────────────────────
# FEATURE FLAGS
# ───────────────────────────────────────────────────────────────

# [OPTIONAL] Enable/disable features
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_CHAT=false
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
NEXT_PUBLIC_ENABLE_DARK_MODE=true
NEXT_PUBLIC_MAINTENANCE_MODE=false


# ═══════════════════════════════════════════════════════════════
# QUICK START CHECKLIST
# ═══════════════════════════════════════════════════════════════
#
# Minimum required for local development:
# ✅ DATABASE_URL
# ✅ NEXTAUTH_SECRET
# ✅ NEXTAUTH_URL
#
# For full functionality, also add:
# ✅ GOOGLE_CLIENT_ID & GOOGLE_CLIENT_SECRET (OAuth)
# ✅ STRIPE_SECRET_KEY & NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY (Payments)
# ✅ UPLOADTHING_SECRET & UPLOADTHING_APP_ID (File uploads)
# ✅ RESEND_API_KEY or EMAIL_SERVER_* (Email)
#
# ═══════════════════════════════════════════════════════════════
