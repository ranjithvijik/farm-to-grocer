# ═══════════════════════════════════════════════════════════════
# FARM-TO-GROCER MVP - GIT IGNORE
# ═══════════════════════════════════════════════════════════════
# Comprehensive .gitignore for Next.js + TypeScript + Prisma project


# ───────────────────────────────────────────────────────────────
# DEPENDENCIES
# ───────────────────────────────────────────────────────────────

node_modules/
.pnp/
.pnp.js
.yarn/install-state.gz


# ───────────────────────────────────────────────────────────────
# NEXT.JS BUILD OUTPUT
# ───────────────────────────────────────────────────────────────

.next/
out/
build/
dist/

# Next.js static export
/out/

# Vercel
.vercel/


# ───────────────────────────────────────────────────────────────
# ENVIRONMENT VARIABLES
# ───────────────────────────────────────────────────────────────

# Local environment files (NEVER commit these!)
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local

# Keep the example file
!.env.example


# ───────────────────────────────────────────────────────────────
# DATABASE
# ───────────────────────────────────────────────────────────────

# Prisma
prisma/migrations/**/migration_lock.toml

# SQLite (if using for local dev)
*.db
*.db-journal
*.sqlite
*.sqlite3

# Database dumps
*.sql
*.dump
!prisma/seed.sql


# ───────────────────────────────────────────────────────────────
# TESTING
# ───────────────────────────────────────────────────────────────

# Jest
coverage/
.jest/

# Playwright
playwright-report/
playwright/.cache/
test-results/

# Cypress
cypress/videos/
cypress/screenshots/
cypress/downloads/


# ───────────────────────────────────────────────────────────────
# TYPESCRIPT
# ───────────────────────────────────────────────────────────────

# TypeScript cache
*.tsbuildinfo
next-env.d.ts


# ───────────────────────────────────────────────────────────────
# LOGS & DEBUG
# ───────────────────────────────────────────────────────────────

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Debug
.debug/


# ───────────────────────────────────────────────────────────────
# IDE & EDITORS
# ───────────────────────────────────────────────────────────────

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
.history/

# JetBrains (WebStorm, IntelliJ)
.idea/
*.iml
*.ipr
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc


# ───────────────────────────────────────────────────────────────
# OPERATING SYSTEM
# ───────────────────────────────────────────────────────────────

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*


# ───────────────────────────────────────────────────────────────
# PACKAGE MANAGERS
# ───────────────────────────────────────────────────────────────

# npm
package-lock.json

# Yarn
# yarn.lock  # Uncomment if using pnpm
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# pnpm
# pnpm-lock.yaml  # Uncomment if using npm or yarn


# ───────────────────────────────────────────────────────────────
# UPLOADS & USER CONTENT
# ───────────────────────────────────────────────────────────────

# Uploaded files (local storage)
uploads/
public/uploads/
tmp/
temp/

# User-generated content
public/user-content/


# ───────────────────────────────────────────────────────────────
# CERTIFICATES & SECRETS
# ───────────────────────────────────────────────────────────────

# SSL certificates
*.pem
*.key
*.crt
*.csr
*.p12
*.pfx

# SSH keys
id_rsa
id_rsa.pub
id_dsa
id_dsa.pub
id_ecdsa
id_ecdsa.pub
id_ed25519
id_ed25519.pub

# API keys and secrets
secrets/
.secrets/
*.secret


# ───────────────────────────────────────────────────────────────
# DOCKER
# ───────────────────────────────────────────────────────────────

# Docker
.docker/
docker-compose.override.yml


# ───────────────────────────────────────────────────────────────
# ANALYTICS & MONITORING
# ───────────────────────────────────────────────────────────────

# Sentry
.sentryclirc

# Bundle analyzer
analyze/
.analyze/


# ───────────────────────────────────────────────────────────────
# STORYBOOK
# ───────────────────────────────────────────────────────────────

storybook-static/
*storybook.log


# ───────────────────────────────────────────────────────────────
# MISCELLANEOUS
# ───────────────────────────────────────────────────────────────

# Turbo
.turbo/

# Cache directories
.cache/
.parcel-cache/
.eslintcache
.stylelintcache

# Temporary files
*.tmp
*.temp
*.bak
*.backup

# Archives
*.zip
*.tar
*.tar.gz
*.rar
*.7z

# Generated files
generated/
.generated/

# Local scripts
local/
.local/

# Notes and documentation (personal)
notes.md
TODO.md
NOTES.md
*.local.md


# ───────────────────────────────────────────────────────────────
# OPTIONAL: UNCOMMENT IF NEEDED
# ───────────────────────────────────────────────────────────────

# Ignore all .map files (source maps)
# *.map

# Ignore specific folders
# /private/
# /scratch/

